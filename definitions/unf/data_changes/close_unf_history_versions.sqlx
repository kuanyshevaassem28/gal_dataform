config {
  type: "operations",
  schema: "gal_unf",
  name: "close_unf_history_versions",
  tags: ["unf_data_changes", "unf", "data_changes", "scd2", "close_versions"],
  description: "Закрытие актуальных версий (is_current=false) по данным external_staging_unf_data_changes"
}

DECLARE current_dt DATETIME DEFAULT CURRENT_DATETIME('Asia/Almaty');

--------------------------------------------------------------------------------
-- Документ.ЗаказПокупателя
--------------------------------------------------------------------------------
UPDATE `galery-22579.gal_unf.history_unf_orders`
SET is_current = FALSE,
    valid_to   = current_dt
WHERE is_current = TRUE
  AND document_id IN (
    SELECT CAST(object_id AS STRING)
    FROM `galery-22579.gal_unf.external_staging_unf_data_changes`
    WHERE object_type = "Документ.ЗаказПокупателя"
);

--------------------------------------------------------------------------------
-- Документ.РасходнаяНакладная
--------------------------------------------------------------------------------
UPDATE `galery-22579.gal_unf.history_unf_sales`
SET is_current = FALSE,
    valid_to   = current_dt
WHERE is_current = TRUE
  AND document_id IN (
    SELECT CAST(object_id AS STRING)
    FROM `galery-22579.gal_unf.external_staging_unf_data_changes`
    WHERE object_type = "Документ.РасходнаяНакладная"
);

--------------------------------------------------------------------------------
