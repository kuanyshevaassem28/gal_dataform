config {
  type: "operations",
  schema: "yandex_ads_data",
  name: "history_yandex_ads_data_avers",
  hasOutput: true,
  tags: ["yandex_ads_data_avers", "yandex_ads", "avers", "history", "scd2"],
  description: "Yandex Ads (Avers) — SCD-2 история по surrogate_key (Date+CampaignId+AdGroupId+AdId) с hash_diff по метрикам (Impressions, Clicks, Cost).",
  columns: {
    Date: "Дата показа объявления (DATE)",
    CampaignId: "ID рекламной кампании",
    CampaignName: "Название кампании",
    CampaignType: "Тип кампании",
    AdGroupId: "ID группы объявлений",
    AdGroupName: "Название группы объявлений",
    AdId: "ID объявления",
    Impressions: "Показы за день",
    Clicks: "Клики за день",
    Cost: "Стоимость (рубли)",
    surrogate_key: "BK: Date|CampaignId|AdGroupId|AdId (SHA256 HEX)",
    is_current: "Признак актуальной записи",
    valid_from: "Дата начала актуальности версии (SCD2)",
    valid_to: "Дата закрытия версии (SCD2)"
  }
}
 

DECLARE run_dt DATETIME DEFAULT CURRENT_DATETIME("Asia/Almaty");

-- создаём таблицу если её нет
CREATE TABLE IF NOT EXISTS ${self()} (
  Date DATE,
  CampaignId STRING,
  CampaignName STRING,
  CampaignType STRING,
  AdGroupId STRING,
  AdGroupName STRING,
  AdId STRING,
  Impressions INT64,
  Clicks INT64,
  Cost FLOAT64,
  surrogate_key STRING,
  is_current BOOL,
  valid_from DATETIME,
  valid_to DATETIME
);

MERGE ${self()} t
USING (

  WITH s AS (
    SELECT
      Date,
      CampaignId,
      CampaignName,
      CampaignType,
      AdGroupId,
      AdGroupName,
      AdId,
      Impressions,
      Clicks,
      Cost,
      surrogate_key
    FROM ${ref("staging_yandex_ads_data_avers")}
  ),

  h_cur AS (
    SELECT *
    FROM ${self()}
    WHERE is_current = TRUE
  ),

  diff AS (
    SELECT
      s.*,
      h_cur.valid_from AS old_valid_from,

      -- новый ключ
      (h_cur.surrogate_key IS NULL) AS is_new,

      -- изменились метрики
      (
        h_cur.surrogate_key IS NOT NULL AND (
             s.Impressions IS DISTINCT FROM h_cur.Impressions
          OR s.Clicks      IS DISTINCT FROM h_cur.Clicks
          OR s.Cost        IS DISTINCT FROM h_cur.Cost
        )
      ) AS is_changed

    FROM s
    LEFT JOIN h_cur
      ON s.surrogate_key = h_cur.surrogate_key
  ),

  rows_to_merge AS (

    -- 1️⃣ закрываем старую версию
    SELECT
      surrogate_key,
      old_valid_from AS valid_from,
      run_dt AS valid_to,
      FALSE AS is_current,
      NULL AS Date,
      NULL AS CampaignId,
      NULL AS CampaignName,
      NULL AS CampaignType,
      NULL AS AdGroupId,
      NULL AS AdGroupName,
      NULL AS AdId,
      NULL AS Impressions,
      NULL AS Clicks,
      NULL AS Cost,
      'U' AS op
    FROM diff
    WHERE is_changed = TRUE

    UNION ALL

    -- 2️⃣ вставляем новую версию
    SELECT
      surrogate_key,
      run_dt AS valid_from,
      NULL AS valid_to,
      TRUE AS is_current,
      Date,
      CampaignId,
      CampaignName,
      CampaignType,
      AdGroupId,
      AdGroupName,
      AdId,
      Impressions,
      Clicks,
      Cost,
      'I' AS op
    FROM diff
    WHERE is_new = TRUE OR is_changed = TRUE
  )

  SELECT * FROM rows_to_merge

) s

ON t.surrogate_key = s.surrogate_key
AND t.valid_from   = s.valid_from

WHEN MATCHED AND s.op = 'U' THEN
  UPDATE SET
    is_current = FALSE,
    valid_to   = s.valid_to

WHEN NOT MATCHED AND s.op = 'I' THEN
  INSERT (
    Date,
    CampaignId,
    CampaignName,
    CampaignType,
    AdGroupId,
    AdGroupName,
    AdId,
    Impressions,
    Clicks,
    Cost,
    surrogate_key,
    is_current,
    valid_from,
    valid_to
  )
  VALUES (
    s.Date,
    s.CampaignId,
    s.CampaignName,
    s.CampaignType,
    s.AdGroupId,
    s.AdGroupName,
    s.AdId,
    s.Impressions,
    s.Clicks,
    s.Cost,
    s.surrogate_key,
    TRUE,
    s.valid_from,
    NULL
  );
